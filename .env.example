# ── env.example ────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values for your local environment.
# NEVER commit .env — it is in .gitignore for a reason.
# Add new variables here with a placeholder value when you add them to the project.

# App
APP_ENV=development       # development | staging | production
APP_DEBUG=true
APP_SECRET_KEY=your-secret-key-here

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/your_db_name

# External APIs
SOME_API_KEY=your-api-key-here
SOME_API_SECRET=your-api-secret-here

# Other
LOG_LEVEL=INFO
